  };

  newFileBtn.addEventListener("click", () => fileInput.click());
  fileInput.addEventListener("change", (e) => handleUpload(e.target.files));

  newFolderBtn.addEventListener("click", async () => {
  const folderName = await showModal({
    type: "prompt",
    title: "New Folder",
    confirmText: "Create",
  });
  if (!folderName) return;
  const workspaceId = getActiveWorkspaceId();
  const prefix = currentPath.length > 0 ? currentPath.join("/") + "/" : "";
  const dummyPath = `${workspaceId}/${prefix}${folderName}/.emptyFolderPlaceholder`;
  const supabase = await getSupabaseClient();

  uploadStatus.classList.remove("hidden");
  uploadStatus.textContent = "Creating folder...";
  try {
    const { error } = await supabase.storage
      .from("user_files")
      .upload(dummyPath, new Blob([""]));
    if (error) {
      console.error(`Failed to create folder "${folderName}":`, error);
      uploadStatus.textContent = `Failed to create folder: ${error.message}`;
      setTimeout(() => uploadStatus.classList.add("hidden"), 6000);
      return;
    }
    uploadStatus.classList.add("hidden");
  } catch (err) {
    console.error(`Folder creation threw for "${folderName}":`, err);
    uploadStatus.textContent = `Failed to create folder: ${err?.message || "Unknown error"}`;
    setTimeout(() => uploadStatus.classList.add("hidden"), 6000);
    return;
  }
  loadFiles();
});

  async function handleUpload(files) {
  if (!files || files.length === 0) return;
  const workspaceId = getActiveWorkspaceId();
  const prefix = currentPath.length > 0 ? currentPath.join("/") + "/" : "";
  const supabase = await getSupabaseClient();

  const total = files.length;
  const failed = [];

  uploadStatus.classList.remove("hidden");

  let i = 0;
  for (const file of files) {
    i++;
    uploadStatus.textContent =
      total === 1 ? "Uploading..." : `Uploading ${i} of ${total}...`;

    const filePath = `${workspaceId}/${prefix}${Date.now()}_${file.name}`;
    try {
      const { error } = await supabase.storage
        .from("user_files")
        .upload(filePath, file);
      if (error) {
        console.error(`Upload failed for "${file.name}":`, error);
        failed.push({ name: file.name, message: error.message });
      }
    } catch (err) {
      console.error(`Upload threw for "${file.name}":`, err);
      failed.push({
        name: file.name,
        message: err?.message || "Unknown error",
      });
    }
  }

  if (failed.length === 0) {
    uploadStatus.classList.add("hidden");
  } else {
    const successCount = total - failed.length;
    uploadStatus.textContent =
      failed.length === total
        ? `Upload failed (${failed.length} file${failed.length === 1 ? "" : "s"}). Check console for details.`
        : `Uploaded ${successCount} of ${total}. ${failed.length} failed — check console.`;
    // Auto-hide the error banner after 6s so it doesn't get stuck
    setTimeout(() => uploadStatus.classList.add("hidden"), 6000);
  }

  loadFiles();
}

  // --- Targeted Drag & Drop Logic ---
  let dragCounter = 0;

  driveMain.addEventListener("dragenter", (e) => {
    e.preventDefault();
    // Only show the big upload overlay if we are dragging actual files from the OS
    if (e.dataTransfer.types.includes("Files")) {
      dragCounter++;
      dragOverlay.classList.remove("hidden");
    }
  });

  driveMain.addEventListener("dragleave", (e) => {
    e.preventDefault();
    if (e.dataTransfer.types.includes("Files")) {
      dragCounter--;
      if (dragCounter === 0) dragOverlay.classList.add("hidden");
    }
  });

  driveMain.addEventListener("dragover", (e) => e.preventDefault());

  driveMain.addEventListener("drop", (e) => {
    e.preventDefault();
    dragCounter = 0;
    dragOverlay.classList.add("hidden");

    // Check if it's an external file upload
    if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
      handleUpload(e.dataTransfer.files);
    }
  });

  async function loadFiles(searchQuery = "") {
    const workspaceId = getActiveWorkspaceId();
    const supabase = await getSupabaseClient();
    const isAdmin = checkAdminPrivileges();
    const prefix = currentPath.length > 0 ? currentPath.join("/") + "/" : "";

    container.innerHTML = '<p class="text-gray-400 text-sm">Loading...</p>';

    let folders = [];
    let files = [];

    if (searchQuery) {
      // Recursive search across the workspace
      let allFiles = [];
      const queue = [workspaceId];

      while (queue.length > 0) {
        const currentDir = queue.shift();
        const { data, error } = await supabase.storage
          .from("user_files")
          .list(currentDir, { limit: 100 });

        if (data) {
          for (const item of data) {
            if (item.name === ".emptyFolderPlaceholder") continue;

            if (!item.id) {
              // it's a folder, enqueue it
              queue.push(`${currentDir}/${item.name}`);
            } else {
              // it's a file, check if it matches search
              const cleanName = item.name.replace(/^\d+_/, "");
              if (cleanName.toLowerCase().includes(searchQuery.toLowerCase())) {
                const p = `${currentDir}/${item.name}`;
                allFiles.push({
                  ...item,
                  name: item.name,
                  displayPath: `${currentDir.replace(
                    workspaceId,
                    ""
                  )}/${cleanName}`.substring(1),
                  fullPath: p,
                });
                window.itemMetadataMap[p] = item;
              }
            }
          }
        }
      }
      files = allFiles;
      // We do not show folders in search results per request
      folders = [];

      if (files.length === 0) {
        return (container.innerHTML = `<div class="py-10 text-center text-gray-400 text-sm w-full border-2 border-dashed border-gray-100 rounded-xl">
            <svg class="w-12 h-12 mx-auto mb-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            No files match your search "${searchQuery}".
          </div>`);
      }
    } else {
      // Normal single-directory load
      const searchPath = `${workspaceId}${
        prefix ? "/" + prefix.slice(0, -1) : ""
      }`;
      const { data, error } = await supabase.storage
        .from("user_files")
        .list(searchPath, {
          limit: 100,
          sortBy: { column: "created_at", order: "desc" },
        });

      if (error)
        return (container.innerHTML =
          '<p class="text-red-500 text-sm">Failed to load folder.</p>');

      const validItems =
        data?.filter((f) => !f.name.endsWith(".emptyFolderPlaceholder")) || [];

      if (validItems.length === 0) {
        return (container.innerHTML =
          '<div class="py-10 text-center text-gray-400 text-sm w-full border-2 border-dashed border-gray-100 rounded-xl">This folder is empty.</div>');
      }

      folders = validItems.filter((item) => !item.id);
      validItems.forEach((i) => {
        const p = `${searchPath}/${i.name}`;
        if (!i.id) i._fullPath = p;
        window.itemMetadataMap[p] = i;
      });
      files = validItems
        .filter((item) => item.id)
        .map((f) => ({ ...f, fullPath: `${searchPath}/${f.name}` }));
    }

    // Apply Sorting to Files
    files.sort((a, b) => {
      const nameA = a.name.replace(/^\d+_/, "").toLowerCase();
      const nameB = b.name.replace(/^\d+_/, "").toLowerCase();
      if (currentSort === "name-asc") return nameA.localeCompare(nameB);
      if (currentSort === "name-desc") return nameB.localeCompare(nameA);

      const timeA = new Date(a.created_at || 0).getTime();
      const timeB = new Date(b.created_at || 0).getTime();
      return timeB - timeA;
    });

    // Handle Favorites Sorting
    const favPaths = getFavoritedFiles();
    const favoritedFiles = files.filter((f) => favPaths.includes(f.fullPath));
    const normalFiles = files.filter((f) => !favPaths.includes(f.fullPath));
    files = [...favoritedFiles, ...normalFiles];

    container.innerHTML = "";

    // Split Folders into Pinned and Normal
    let pinnedFolders = [];
    let normalFolders = [];
    if (folders.length > 0) {
      const pinnedPaths = getPinnedFolders();
      folders.forEach((folder) => {
        const folderFullPath = searchQuery
          ? `${workspaceId}/${folder.name}`
          : `${workspaceId}/${prefix}${folder.name}`;

        folder._fullPath = folderFullPath; // Store for later

        if (pinnedPaths.includes(folderFullPath)) {
          pinnedFolders.push(folder);
        } else {
          normalFolders.push(folder);
        }
      });
    }

    const renderFolderGroup = (folderGroup, title, isPinnedSection) => {
      const folderSection = document.createElement("div");
      folderSection.innerHTML = `<h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">${title}</h3>`;
      const folderGrid = document.createElement("div");
      folderGrid.className =
        "grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4 mb-6";

      folderGroup.forEach((folder) => {
        const folderDisplayName = folder.name.replace(/\/$/, "");
        const folderFullPath = folder._fullPath;

        const card = document.createElement("div");
        card.className =
          "group flex items-center gap-3 p-3 rounded-xl border border-gray-200 bg-gray-50 hover:bg-blue-50 hover:border-blue-300 cursor-pointer transition-colors";
        card.setAttribute("data-item-path", folderFullPath);
        card.setAttribute("data-item-name", folderDisplayName);
        card.setAttribute("data-item-type", "folder");
        card.draggable = isAdmin;
        card.ondragstart = (e) => {
          if (selectedItems.has(folderFullPath)) {
            const items = Array.from(selectedItems).map((p) => ({
              path: p,
              type: window.itemMetadataMap[p]?.id ? "file" : "folder",
            }));
            e.dataTransfer.setData(
              "application/json",
              JSON.stringify({ multiple: true, items })
            );
          } else {
            e.dataTransfer.setData(
              "application/json",
              JSON.stringify({ path: folderFullPath, type: "folder" })
            );
          }
        };

        // Folder Drop Logic
        card.ondragover = (e) => {
          e.preventDefault();
          card.classList.add("ring-2", "ring-blue-400", "bg-blue-100");
        };
        card.ondragleave = () =>
          card.classList.remove("ring-2", "ring-blue-400", "bg-blue-100");
        card.ondrop = (e) => {
          e.preventDefault();
          card.classList.remove("ring-2", "ring-blue-400", "bg-blue-100");
          window.moveFileToFolder(e, folderDisplayName);
        };

        const preSelected = selectedItems.has(folderFullPath)
          ? "ring-2 ring-blue-500 bg-blue-50"
          : "";
        if (preSelected) card.className += " ring-2 ring-blue-500 bg-blue-50";

        card.onclick = () => {
          if (isSelectMode)
            return window.toggleSelectItem(folderFullPath, card);
          if (searchQuery) {
            const globalSearch = document.getElementById("global-search");
            if (globalSearch) globalSearch.value = "";
            currentPath = folderDisplayName.split("/").filter(Boolean);
          } else {
            currentPath.push(folderDisplayName);
          }
          refreshUI();
        };
        card.innerHTML = `
          <div class="relative">
            <svg class="w-10 h-10 text-blue-400/80 pointer-events-none drop-shadow-sm" fill="currentColor" viewBox="0 0 20 20"><path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z"></path></svg>
            ${
              isPinnedSection
                ? '<div class="absolute -top-1 -right-1 bg-white rounded-full p-0.5 shadow-sm border border-gray-100"><svg class="w-3 h-3 text-blue-600" fill="currentColor" viewBox="0 0 20 20"><path d="M5 4a2 2 0 012-2h6a2 2 0 012 2v14l-5-2.5L5 18V4z"></path></svg></div>'
                : ""
            }
          </div>
          <span class="text-sm font-semibold text-slate-700 truncate pointer-events-none group-hover:text-blue-600 transition-colors" title="${folderDisplayName}">${folderDisplayName}</span>
        `;
        folderGrid.appendChild(card);
      });
      folderSection.appendChild(folderGrid);
      container.appendChild(folderSection);
    };

    if (pinnedFolders.length > 0)
      renderFolderGroup(pinnedFolders, "Pinned Folders", true);
    if (normalFolders.length > 0)
      renderFolderGroup(normalFolders, "Folders", false);

    // Render Files Section
    if (files.length > 0) {
      const fileSection = document.createElement("div");
      fileSection.innerHTML = `<h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Files</h3>`;
      const fileGrid = document.createElement("div");
      fileGrid.className =
        "grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-5";

      // 1) Pre-fetch image urls for previews
      let signedUrlMap = {};
      const imageFiles = files.filter((f) =>
        /\.(png|jpe?g|gif|webp|svg)$/i.test(f.name)
      );
      const imagePathsToFetch = imageFiles.map((f) => f.fullPath);

      if (imagePathsToFetch.length > 0) {
        try {
          const { data: signedUrls } = await supabase.storage
            .from("user_files")
            .createSignedUrls(imagePathsToFetch, 3600);
          if (signedUrls) {
            signedUrls.forEach((u) => (signedUrlMap[u.path] = u.signedUrl));
          }
        } catch (err) {
          console.error("Failed to load image previews", err);
        }
      }

      files.forEach((file) => {
        const fullPath = file.fullPath;
        const baseName = file.name.split("/").pop();
        const cleanFileName = baseName.replace(/^\d+_/, "");
        const displayName = searchQuery ? file.displayPath : cleanFileName;

        const extMatch = cleanFileName.match(/\.([^.]+)$/);
        const ext = extMatch ? extMatch[1].toLowerCase() : "";

        const card = document.createElement("div");
        card.setAttribute("data-item-path", fullPath);
        card.setAttribute("data-item-name", cleanFileName);
        card.setAttribute("data-item-type", "file");
        // File Drag Logic
        card.draggable = isAdmin; // Only allow admins to drag files
        card.ondragstart = (e) => {
          if (selectedItems.has(fullPath)) {
            const items = Array.from(selectedItems).map((p) => ({
              path: p,
              type: window.itemMetadataMap[p]?.id ? "file" : "folder",
            }));
            e.dataTransfer.setData(
              "application/json",
              JSON.stringify({ multiple: true, items })
            );
          } else {
            e.dataTransfer.setData(
              "application/json",
              JSON.stringify({ path: fullPath, type: "file" })
            );
          }
        };
        const preSelected = selectedItems.has(fullPath)
          ? "ring-2 ring-blue-500 bg-blue-50"
          : "";
        card.className = `relative group flex flex-col justify-between p-4 rounded-xl border border-gray-200 bg-white hover:border-blue-300 hover:shadow-md transition-all ${preSelected} ${
          isAdmin ? "cursor-grab active:cursor-grabbing" : ""
        }`;

        let iconHtml = "";
        const isImage = /^(png|jpe?g|gif|webp|svg)$/.test(ext);
        const isDoc =
          /^(doc|docx|txt|rtf|pdf|odt|pages|csv|xls|xlsx|ppt|pptx)$/.test(ext);
        const isCode =
          /^(js|ts|html|css|jsx|tsx|py|java|c|cpp|json|md|php|sh|yml|yaml)$/.test(
            ext
          );
        const isArchive = /^(zip|rar|7z|tar|gz)$/.test(ext);
        const isAudio = /^(mp3|wav|ogg|flac|m4a)$/.test(ext);
        const isVideo = /^(mp4|mov|avi|mkv|webm)$/.test(ext);

        if (isImage && signedUrlMap[fullPath]) {
          iconHtml = `<img src="${signedUrlMap[fullPath]}" class="w-full h-full object-cover rounded pointer-events-none drop-shadow-sm" alt="${cleanFileName}" loading="lazy" />`;
        } else if (isDoc) {
          iconHtml = `<svg class="w-8 h-8 text-blue-500 group-hover:scale-110 transition-transform pointer-events-none drop-shadow-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>`;
        } else if (isCode) {
          iconHtml = `<svg class="w-8 h-8 text-orange-500 group-hover:scale-110 transition-transform pointer-events-none drop-shadow-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>`;
        } else if (isArchive) {
          iconHtml = `<svg class="w-8 h-8 text-yellow-600 group-hover:scale-110 transition-transform pointer-events-none drop-shadow-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path></svg>`;
        } else if (isAudio) {
          iconHtml = `<svg class="w-8 h-8 text-purple-500 group-hover:scale-110 transition-transform pointer-events-none drop-shadow-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path></svg>`;
        } else if (isVideo) {
          iconHtml = `<svg class="w-8 h-8 text-rose-500 group-hover:scale-110 transition-transform pointer-events-none drop-shadow-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>`;
        } else {
          iconHtml = `<svg class="w-8 h-8 text-gray-400 group-hover:text-blue-500 group-hover:scale-110 transition-all pointer-events-none drop-shadow-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>`;
        }

        card.onclick = (e) => {
          if (e.target.closest("button")) return;
          if (isSelectMode) {
            window.toggleSelectItem(fullPath, card);
          } else {
            window.triggerPreview(fullPath);
          }
        };
        card.innerHTML = `
          <div class="mb-4 flex flex-col items-center cursor-pointer">
            <div class="w-14 h-14 mb-3 flex items-center justify-center pointer-events-none">
              ${iconHtml}
            </div>
            <span class="block w-full text-xs font-semibold text-gray-700 truncate text-center pointer-events-none" title="${displayName}">${displayName}</span>
            ${
              favPaths.includes(fullPath)
                ? '<div class="absolute top-2 right-2 text-yellow-400 pointer-events-none"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg></div>'
                : ""
            }
          </div>
          <div class="flex justify-between items-center border-t border-gray-100 pt-3 mt-auto">
            ${
              isAdmin
                ? `<button class="text-[11px] font-medium text-gray-500 hover:text-red-600 px-1" onclick="window.triggerDelete('${fullPath}', 'file')">Delete</button>`
                : `<span class="text-[10px] font-bold uppercase text-gray-300 tracking-wider">Read Only</span>`
            }
            <button class="text-gray-400 hover:text-blue-600 ml-auto" onclick="window.triggerDownload('${fullPath}', '${cleanFileName}')"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg></button>
          </div>
        `;
        fileGrid.appendChild(card);
      });
      fileSection.appendChild(fileGrid);
      container.appendChild(fileSection);
    }
  }

  // File Moving Logic
  window.moveFileToFolder = async (e, targetFolderName) => {
    const dragData = JSON.parse(
      e.dataTransfer.getData("application/json") || "{}"
    );

    const workspaceId = getActiveWorkspaceId();
    const prefix = currentPath.length > 0 ? currentPath.join("/") + "/" : "";
    const targetPath = `${workspaceId}/${prefix}${targetFolderName}`;

    const supabase = await getSupabaseClient();

    if (dragData.multiple) {
      uploadStatus.classList.remove("hidden");
      uploadStatus.textContent = "Moving bulk...";
      for (const item of dragData.items) {
        const oldP = item.path;
        if (!oldP) continue;
        const fName = oldP.split("/").pop();
        const newP = `${targetPath}/${fName}`;
        if (oldP === newP || oldP === targetPath) continue;

        if (item.type === "folder") {
          const { data: filesToMove } = await supabase.storage
            .from("user_files")
            .list(oldP, { limit: 100 });
          if (filesToMove) {
            for (const file of filesToMove) {
              await supabase.storage
                .from("user_files")
                .move(`${oldP}/${file.name}`, `${newP}/${file.name}`);
            }
          }
        } else {
          await supabase.storage.from("user_files").move(oldP, newP);
        }
      }
      uploadStatus.classList.add("hidden");
      selectedItems.clear();
      loadFiles();
      return;
    }
    const oldPath = dragData.path;

    if (!oldPath) return;

    const fileName = oldPath.split("/").pop();
    const newPath = `${targetPath}/${fileName}`;

    // Prevent moving a folder into itself
    if (oldPath === newPath || oldPath === targetPath) return;

    uploadStatus.classList.remove("hidden");
    uploadStatus.textContent = "Moving...";

    await supabase.storage.from("user_files").move(oldPath, newPath);

    uploadStatus.classList.add("hidden");
    loadFiles();
  };

  const previewModal = document.getElementById("preview-modal");
  const previewContentContainer = document.getElementById(
    "preview-content-container"
  );
  const previewClose = document.getElementById("preview-close");
  const previewDownloadBtn = document.getElementById("preview-download");
  const previewPrevBtn = document.getElementById("preview-prev");
  const previewNextBtn = document.getElementById("preview-next");

  // State for preview navigation
  let previewSiblings = []; // [{ path, name }, ...] — snapshot at open time
  let previewIndex = -1;

  function collectPreviewableSiblings() {
    const cards = document.querySelectorAll(
      '[data-item-path][data-item-type="file"]'
    );
    const siblings = [];
    cards.forEach((card) => {
      const path = card.getAttribute("data-item-path");
      const name = card.getAttribute("data-item-name") || "";
      const extMatch = name.match(/\.([^.]+)$/);
      const ext = extMatch ? extMatch[1].toLowerCase() : "";
      if (/^(png|jpe?g|gif|webp|svg|pdf)$/.test(ext)) {
        siblings.push({ path, name });
      }
    });
    return siblings;
  }

  function updatePreviewNavVisibility() {
    const hasMultiple = previewSiblings.length > 1;
    if (previewPrevBtn)
      previewPrevBtn.classList.toggle("hidden", !hasMultiple);
    if (previewNextBtn)
      previewNextBtn.classList.toggle("hidden", !hasMultiple);
  }

  function showPreviewAtOffset(delta) {
    if (previewSiblings.length === 0) return;
    const len = previewSiblings.length;
    // Wrap-around modulo (handles negative delta too)
    previewIndex = ((previewIndex + delta) % len + len) % len;
    window.triggerPreview(previewSiblings[previewIndex].path);
  }

  if (previewPrevBtn) previewPrevBtn.onclick = () => showPreviewAtOffset(-1);
  if (previewNextBtn) previewNextBtn.onclick = () => showPreviewAtOffset(1);
  if (previewClose && previewModal) {
    previewClose.onclick = () => {
      previewModal.classList.remove("opacity-100");
      setTimeout(() => {
        previewModal.classList.add("hidden");
        previewModal.classList.remove("flex");
        previewContentContainer.innerHTML = "";
      }, 200);
    };

    document.addEventListener("keydown", (e) => {
  if (previewModal.classList.contains("hidden")) return;
  if (e.key === "Escape") {
    previewClose.click();
  } else if (e.key === "ArrowLeft") {
    e.preventDefault();
    showPreviewAtOffset(-1);
  } else if (e.key === "ArrowRight") {
    e.preventDefault();
    showPreviewAtOffset(1);
  }
});
  }

  window.triggerPreview = async (path) => {
    const extMatch = path.match(/\.([^.]+)$/);
    const ext = extMatch ? extMatch[1].toLowerCase() : "";
    const isImage = /^(png|jpe?g|gif|webp|svg)$/.test(ext);
    const isPdf = /^pdf$/.test(ext);

    const supabase = await getSupabaseClient();
    const { data } = await supabase.storage
      .from("user_files")
      .createSignedUrl(path, 60);

    if (isImage || isPdf) {
      if (!previewModal) return window.open(data.signedUrl, "_blank");
      // Snapshot siblings on first open; just update the index on subsequent nav
      const isOpening = previewModal.classList.contains("hidden");
      if (isOpening) previewSiblings = collectPreviewableSiblings();
      previewIndex = previewSiblings.findIndex((s) => s.path === path);
      if (previewIndex === -1) {
        // Path not in current snapshot (DOM changed) — refresh
        previewSiblings = collectPreviewableSiblings();
        previewIndex = previewSiblings.findIndex((s) => s.path === path);
      }
  updatePreviewNavVisibility();

      previewModal.classList.remove("hidden");
      previewModal.classList.add("flex");
      // slight delay for transition
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          previewModal.classList.add("opacity-100");
        });
      });

      previewDownloadBtn.onclick = () => {
        const fileName = path.split("/").pop().replace(/^\d+_/, "");
        window.triggerDownload(path, fileName);
      };

      if (isImage) {
        previewContentContainer.innerHTML = `<img src="${data.signedUrl}" class="max-w-full max-h-full object-contain rounded-lg shadow-2xl" />`;
      } else if (isPdf) {
        previewContentContainer.innerHTML = `<iframe src="${data.signedUrl}" class="w-full h-full rounded-lg shadow-2xl bg-white border-0"></iframe>`;
      }
    } else {
      window.open(data.signedUrl, "_blank");
    }
  };

  window.triggerDownload = async (path, fileName) => {
    const supabase = await getSupabaseClient();
    const { data } = await supabase.storage
      .from("user_files")
      .createSignedUrl(path, 60, { download: fileName });
    const link = document.createElement("a");
    link.href = data.signedUrl;
    link.download = fileName;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  };

  window.triggerRename = async (path, oldName, type) => {
    const newName = await showModal({
      type: "prompt",
      title: `Rename ${type}`,
      defaultValue: oldName,
      confirmText: "Rename",
    });

    if (!newName || newName === oldName) return;

    const supabase = await getSupabaseClient();
    uploadStatus.classList.remove("hidden");
    uploadStatus.textContent = "Renaming...";

    const newPath = path.slice(0, -oldName.length) + newName;

    if (type === "folder") {
      const { data: filesToMove } = await supabase.storage
        .from("user_files")
        .list(path, { limit: 100 });

      if (filesToMove && filesToMove.length > 0) {
        for (const file of filesToMove) {
          const fileOldPath = `${path}/${file.name}`;
          const fileNewPath = `${newPath}/${file.name}`;
          await supabase.storage
            .from("user_files")
            .move(fileOldPath, fileNewPath);
        }
      } else {
        await supabase.storage
          .from("user_files")
          .move(
            `${path}/.emptyFolderPlaceholder`,
            `${newPath}/.emptyFolderPlaceholder`
          );
      }
    } else {
      await supabase.storage.from("user_files").move(path, newPath);
    }

    uploadStatus.classList.add("hidden");
    loadFiles();
  };

  window.triggerDelete = async (path, type) => {
    const confirmed = await showModal({
      type: "confirm",
      title: `Delete ${type || "item"}`,
      message: `Are you sure you want to delete this ${
        type || "item"
      }? This action cannot be undone.`,
      confirmText: "Delete",
      confirmClass:
        "px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 transition-colors shadow-sm shadow-red-600/20",
    });

    if (!confirmed) return;
    const supabase = await getSupabaseClient();
    uploadStatus.classList.remove("hidden");
    uploadStatus.textContent = "Deleting...";

    if (type === "folder") {
      const { data: filesToDelete } = await supabase.storage
        .from("user_files")
        .list(path, { limit: 100 });

      if (filesToDelete && filesToDelete.length > 0) {
        const pathsToRemove = filesToDelete.map(
          (file) => `${path}/${file.name}`
        );
        await supabase.storage
          .from("user_files")
          .remove([...pathsToRemove, path, `${path}/.emptyFolderPlaceholder`]);
      } else {
        await supabase.storage
          .from("user_files")
          .remove([path, `${path}/.emptyFolderPlaceholder`]);
      }
    } else {
      await supabase.storage.from("user_files").remove([path]);
    }

    uploadStatus.classList.add("hidden");
    loadFiles();
  };

  // Search filtering logic
  const globalSearch = document.getElementById("global-search");
  let searchTimeout;
  if (globalSearch) {
    globalSearch.addEventListener("input", (e) => {
      const query = (e.target.value || "").trim().toLowerCase();
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        loadFiles(query);
      }, 300);
    });
  };

  document.addEventListener("keydown", (e) => {
    const target = e.target;
    const isTyping =
      target.tagName === "INPUT" ||
      target.tagName === "TEXTAREA" ||
      target.isContentEditable;

    // Don't intercept browser shortcuts (Cmd/Ctrl/Alt combos)
    if (e.ctrlKey || e.metaKey || e.altKey) return;

    // Esc: close the custom modal if open
    // (the preview modal has its own Esc handler higher up in this file)
    if (e.key === "Escape") {
      const customModal = document.getElementById("custom-modal");
      if (customModal && !customModal.classList.contains("hidden")) {
        const cancel = document.getElementById("modal-cancel");
        if (cancel) cancel.click();
        e.preventDefault();
      }
      return;
    }

    // Skip the rest if the user is typing in a field
    if (isTyping) return;

    // "/" — focus the global search input
    if (e.key === "/") {
      const search = document.getElementById("global-search");
      if (search) {
        e.preventDefault();
        search.focus();
      }
      return;
    }

    // "n" — new folder
    if (e.key === "n") {
      const btn = document.getElementById("new-folder-btn");
      if (btn) {
        e.preventDefault();
        btn.click();
      }
      return;
    }

    // "u" — upload file
    if (e.key === "u") {
      const btn = document.getElementById("new-file-btn");
      if (btn) {
        e.preventDefault();
        btn.click();
      }
      return;
    }

    // "s" — toggle select mode
    if (e.key === "s") {
      const btn = document.getElementById("toggle-select-mode");
      if (btn) {
        e.preventDefault();
        btn.click();
      }
      return;
    }

    // "?" — show keyboard shortcuts help
    if (e.key === "?") {
      e.preventDefault();
      showModal({
        type: "info",
        title: "Keyboard Shortcuts",
        html: `
          <div class="space-y-2 text-sm text-gray-700">
            <div class="flex justify-between items-center"><span>Focus search</span><kbd class="px-2 py-0.5 bg-gray-100 border border-gray-200 rounded text-xs font-mono">/</kbd></div>
            <div class="flex justify-between items-center"><span>New folder</span><kbd class="px-2 py-0.5 bg-gray-100 border border-gray-200 rounded text-xs font-mono">N</kbd></div>
            <div class="flex justify-between items-center"><span>Upload file</span><kbd class="px-2 py-0.5 bg-gray-100 border border-gray-200 rounded text-xs font-mono">U</kbd></div>
            <div class="flex justify-between items-center"><span>Toggle select mode</span><kbd class="px-2 py-0.5 bg-gray-100 border border-gray-200 rounded text-xs font-mono">S</kbd></div>
            <div class="flex justify-between items-center"><span>Close modal</span><kbd class="px-2 py-0.5 bg-gray-100 border border-gray-200 rounded text-xs font-mono">Esc</kbd></div>
            <div class="flex justify-between items-center"><span>Show this help</span><kbd class="px-2 py-0.5 bg-gray-100 border border-gray-200 rounded text-xs font-mono">?</kbd></div>
          </div>
        `,
        confirmText: "Close",
      });
      return;
    }
  });
</script>
