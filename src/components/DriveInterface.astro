---
import { OrganizationSwitcher } from "@clerk/astro/components";
---

<div
  class="flex relative h-[calc(100vh-73px)] w-full overflow-hidden bg-slate-50/50"
>
  <!-- Mobile Overlay -->
  <div
    id="mobile-overlay"
    class="absolute inset-0 bg-slate-900/20 backdrop-blur-sm z-30 hidden sm:hidden opacity-0 transition-opacity duration-300"
  >
  </div>

  <aside
    id="mobile-sidebar"
    class="w-64 p-6 flex flex-col border-r border-slate-200/60 bg-white shadow-[4px_0_12px_-4px_rgba(0,0,0,0.1)] z-40 absolute inset-y-0 left-0 -translate-x-full sm:translate-x-0 sm:relative sm:shadow-[2px_0_8px_-4px_rgba(0,0,0,0.05)] transition-transform duration-300 ease-in-out"
  >
    <div class="mb-6">
      <p
        class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-3 mt-1"
      >
        Workspace
      </p>
      <OrganizationSwitcher
        hidePersonal={false}
        appearance={{
          elements: {
            organizationSwitcherTrigger:
              "w-full justify-start border border-gray-200 bg-white shadow-sm rounded-lg py-2 px-3",
          },
        }}
      />
    </div>

    <div class="space-y-2 mb-8">
      <button
        id="new-file-btn"
        class="flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 active:scale-[0.98] shadow-md shadow-blue-600/20 rounded-xl px-4 py-2.5 transition-all text-sm font-semibold text-white w-full"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
        </svg>
        Upload File
      </button>
      <button
        id="new-folder-btn"
        class="flex items-center justify-center gap-2 bg-white border border-slate-200 hover:border-slate-300 hover:bg-slate-50 active:scale-[0.98] shadow-sm rounded-xl px-4 py-2.5 transition-all text-sm font-medium text-slate-700 w-full"
      >
        <svg
          class="w-4 h-4 text-slate-500"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
          ></path>
        </svg>
        New Folder
      </button>
      <input type="file" id="file-input" class="hidden" multiple />
    </div>

    <div id="team-section" class="flex-1 overflow-y-auto hidden">
      <p
        class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-3 mt-4"
      >
        Team Access
      </p>
      <ul id="team-members-list" class="space-y-3"></ul>
    </div>
  </aside>

  <main
    id="drive-main"
    class="flex-1 relative p-8 overflow-y-auto transition-colors"
  >
    <div
      id="drag-overlay"
      class="absolute inset-4 rounded-2xl border-2 border-blue-400 border-dashed bg-blue-50/95 z-50 flex items-center justify-center hidden pointer-events-none transition-all"
    >
      <div class="text-center">
        <p class="text-2xl font-semibold text-blue-700">
          Drop to upload to this folder
        </p>
      </div>
    </div>

    <div
      class="flex justify-between items-end mb-8 border-b border-gray-100 pb-4"
    >
      <div class="flex items-center">
        <button
          id="mobile-menu-btn"
          class="sm:hidden p-2 -ml-2 mr-2 text-slate-500 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-colors"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
        <nav
          id="breadcrumbs"
          class="flex flex-wrap items-center gap-2 text-xl font-semibold text-gray-800 tracking-tight"
        >
        </nav>
      </div>
      <div class="flex items-center gap-4">
        <button
          id="toggle-select-mode"
          class="text-sm bg-white border border-gray-200 rounded-lg px-3 py-1.5 focus:outline-none hover:bg-blue-50 hover:border-blue-200 hover:text-blue-600 focus:ring-2 focus:ring-blue-500/20 text-gray-700 font-medium cursor-pointer transition-colors active:scale-[0.98]"
        >
          Select: Off
        </button>
        <select
          id="sort-select"
          class="text-sm bg-white border border-gray-200 rounded-lg px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-blue-500/20 text-gray-700 font-medium cursor-pointer"
        >
          <option value="date-desc">Upload Date</option>
          <option value="name-asc">Name (A-Z)</option>
          <option value="name-desc">Name (Z-A)</option>
        </select>
        <span
          id="upload-status"
          class="text-sm font-medium text-blue-600 bg-blue-50 px-3 py-1 rounded-full hidden"
          >Processing...</span
        >
      </div>
    </div>

    <div id="file-list-container" class="space-y-8">
      <p class="text-slate-400 text-sm flex items-center gap-2 mb-8">
        <svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24"
          ><circle
            class="opacity-25"
            cx="12"
            cy="12"
            r="10"
            stroke="currentColor"
            stroke-width="4"></circle><path
            class="opacity-75"
            fill="currentColor"
            d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
          ></path>
        </svg> Loading...
      </p>
    </div>

    <!-- Empty Space Context Menu -->
    <div
      id="bg-context-menu"
      class="hidden fixed z-[100] w-48 bg-white/95 backdrop-blur-xl border border-slate-200/60 rounded-xl shadow-[0_8px_30px_rgb(0,0,0,0.12)] py-1.5 overflow-hidden ring-1 ring-black/5"
    >
      <button
        id="bg-cm-new-folder"
        class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-colors flex items-center gap-2"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
          ></path>
        </svg>
        New Folder
      </button>
      <button
        id="bg-cm-upload"
        class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-colors flex items-center gap-2"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
          ></path>
        </svg>
        Upload File
      </button>
    </div>

    <div
      id="context-menu"
      class="hidden fixed z-[100] w-56 bg-white/95 backdrop-blur-xl border border-slate-200/60 rounded-xl shadow-[0_8px_30px_rgb(0,0,0,0.12)] py-1.5 overflow-hidden ring-1 ring-black/5"
    >
      <button
        id="cm-rename"
        class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-colors flex items-center gap-2"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
          ></path>
        </svg>
        Rename
      </button>
      <button
        id="cm-info"
        class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-colors flex items-center gap-2"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
          ></path>
        </svg>
        Information
      </button>
      <button
        id="cm-download"
        class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-colors flex items-center gap-2"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
          ></path>
        </svg>
        <span id="cm-download-text">Download</span>
      </button>
      <button
        id="cm-copy"
        class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-colors flex items-center gap-2"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
          ></path>
        </svg>
        <span id="cm-copy-text">Duplicate</span>
      </button>
      <button
        id="cm-pin"
        class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-colors flex items-center gap-2"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path>
        </svg>
        <span id="cm-pin-text">Pin Folder</span>
      </button>
      <button
        id="cm-favorite"
        class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-colors flex items-center gap-2"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"
          ></path>
        </svg>
        <span id="cm-favorite-text">Favorite File</span>
      </button>
      <div class="border-t border-gray-100 my-1"></div>
      <button
        id="cm-delete"
        class="w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors flex items-center gap-2 font-medium"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
          ></path>
        </svg>
        <span id="cm-delete-text">Delete</span>
      </button>
    </div>
  </main>
</div>

<!-- Custom Modal Overlay -->
<div
  id="custom-modal"
  class="fixed inset-0 z-[200] hidden items-center justify-center bg-slate-900/40 backdrop-blur-sm transition-opacity opacity-0"
>
  <div
    class="bg-white rounded-2xl shadow-2xl w-full max-w-sm overflow-hidden transform scale-95 transition-transform duration-200 border border-slate-100"
    id="modal-content"
  >
    <div
      class="px-5 py-4 border-b border-slate-100 flex justify-between items-center bg-white"
    >
      <h3 class="text-base font-semibold text-slate-800" id="modal-title">
        Title
      </h3>
      <button
        id="modal-close"
        class="text-slate-400 hover:text-slate-600 transition-colors rounded-full hover:bg-slate-100 p-1"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <div class="px-5 py-5 bg-white">
      <p id="modal-message" class="text-sm text-slate-600 mb-4 hidden"></p>
      <input
        type="text"
        id="modal-input"
        class="w-full px-3 py-2 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all hidden text-sm"
      />
    </div>
    <div
      class="px-5 py-3 bg-slate-50/50 border-t border-slate-100 flex justify-end gap-2"
      id="modal-actions-container"
    >
      <button
        id="modal-cancel"
        class="px-3 py-1.5 text-sm font-medium text-slate-600 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 hover:text-slate-900 transition-colors shadow-sm"
        >Cancel</button
      >
      <button
        id="modal-confirm"
        class="px-3 py-1.5 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors shadow-sm shadow-blue-600/20"
        >Confirm</button
      >
    </div>
  </div>
</div>

<!-- Preview Modal Overlay -->
<div
  id="preview-modal"
  class="fixed inset-0 z-[250] hidden items-center justify-center bg-slate-900/80 backdrop-blur-md transition-opacity duration-200 opacity-0"
>
  <div
    class="relative w-full max-w-5xl h-full max-h-screen p-6 flex flex-col items-center justify-center"
  >
    <!-- Close button & Download -->
    <div class="absolute top-6 right-6 flex gap-3 z-[260]">
      <button
        id="preview-download"
        class="bg-white/10 hover:bg-white/20 text-white rounded-full p-2.5 backdrop-blur-md transition-colors shadow-lg"
        title="Download"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
          ></path>
        </svg>
      </button>
      <button
        id="preview-close"
        class="bg-white/10 hover:bg-white/20 text-white rounded-full p-2.5 backdrop-blur-md transition-colors shadow-lg"
        title="Close"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  <!-- Preview navigation arrows -->
      <button
      id="preview-prev"
      class="absolute left-6 top-1/2 -translate-y-1/2 bg-white/10 hover:bg-white/20 text-white rounded-full p-3 backdrop-blur-md transition-colors shadow-lg z-[260] hidden"
      title="Previous (←)"
      aria-label="Previous file"
      >
      <svg
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 19l-7-7 7-7"></path>
      </svg>
      </button>
      <button
      id="preview-next"
      class="absolute right-6 top-1/2 -translate-y-1/2 bg-white/10 hover:bg-white/20 text-white rounded-full p-3 backdrop-blur-md transition-colors shadow-lg z-[260] hidden"
      title="Next (→)"
      aria-label="Next file"
      >
      <svg
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 5l7 7-7 7"></path>
      </svg>
      </button>
    <div
      id="preview-content-container"
      class="w-full h-[85vh] flex items-center justify-center"
    >
      <!-- Media inserted here dynamically -->
    </div>
  </div>
</div>

<script>
  import { getSupabaseClient } from "../lib/supabase";

  let currentPath = [];
  let activeWorkspaceId = null; // Track this to prevent unnecessary path resets

  const container = document.getElementById("file-list-container");
  const driveMain = document.getElementById("drive-main");
  const dragOverlay = document.getElementById("drag-overlay");
  const newFileBtn = document.getElementById("new-file-btn");
  const newFolderBtn = document.getElementById("new-folder-btn");
  const fileInput = document.getElementById("file-input");
  const uploadStatus = document.getElementById("upload-status");
  const breadcrumbsNav = document.getElementById("breadcrumbs");
  const teamSection = document.getElementById("team-section");
  const teamMembersList = document.getElementById("team-members-list");

  let isSelectMode = false;
  let selectedItems = new Set();
  window.itemMetadataMap = {};
  const bgMenu = document.getElementById("bg-context-menu");

  const toggleSelectBtn = document.getElementById("toggle-select-mode");
  if (toggleSelectBtn) {
    toggleSelectBtn.onclick = () => {
      isSelectMode = !isSelectMode;
      toggleSelectBtn.textContent = isSelectMode ? "Select: On" : "Select: Off";
      toggleSelectBtn.classList.toggle("bg-blue-50", isSelectMode);
      toggleSelectBtn.classList.toggle("text-blue-600", isSelectMode);
      toggleSelectBtn.classList.toggle("border-blue-200", isSelectMode);
      if (!isSelectMode) {
        selectedItems.clear();
        document
          .querySelectorAll("[data-item-path]")
          .forEach((el) =>
            el.classList.remove("ring-2", "ring-blue-500", "bg-blue-50")
          );
      }
    };
  }

  window.toggleSelectItem = (path, el) => {
    if (selectedItems.has(path)) {
      selectedItems.delete(path);
      el.classList.remove("ring-2", "ring-blue-500", "bg-blue-50");
    } else {
      selectedItems.add(path);
      el.classList.add("ring-2", "ring-blue-500", "bg-blue-50");
    }
  };
    // --- Marquee (rubber-band) selection ---
  let marqueeActive = false;
  let marqueeStartX = 0;
  let marqueeStartY = 0;
  let marqueeAdditive = false;
  let marqueeInitialSelection = new Set();
  let marqueeEl = null;

  function ensureMarqueeElement() {
    if (marqueeEl) return marqueeEl;
    marqueeEl = document.createElement("div");
    marqueeEl.id = "marquee-selection";
    marqueeEl.className =
      "absolute pointer-events-none border border-blue-500 bg-blue-500/10 rounded-sm z-40";
    marqueeEl.style.display = "none";
    driveMain.appendChild(marqueeEl);
    return marqueeEl;
  }

  function clearCurrentSelectionVisuals() {
    selectedItems.forEach((path) => {
      const el = document.querySelector(
        `[data-item-path="${CSS.escape(path)}"]`
      );
      if (el) el.classList.remove("ring-2", "ring-blue-500", "bg-blue-50");
    });
    selectedItems.clear();
  }

  driveMain.addEventListener("mousedown", (e) => {
    // Only left-click; ignore clicks that land on interactive children
    if (e.button !== 0) return;
    if (e.target.closest("[data-item-path]")) return;
    if (e.target.closest("button, input, select, a, label")) return;

    marqueeActive = true;
    marqueeAdditive = e.ctrlKey || e.metaKey || e.shiftKey;

    // Auto-enable Select Mode so the UI state matches the outcome
    if (!isSelectMode && toggleSelectBtn) toggleSelectBtn.click();

    ensureMarqueeElement();

    const rect = driveMain.getBoundingClientRect();
    marqueeStartX = e.clientX - rect.left + driveMain.scrollLeft;
    marqueeStartY = e.clientY - rect.top + driveMain.scrollTop;

    if (marqueeAdditive) {
      marqueeInitialSelection = new Set(selectedItems);
    } else {
      clearCurrentSelectionVisuals();
      marqueeInitialSelection = new Set();
    }

    marqueeEl.style.display = "block";
    marqueeEl.style.left = `${marqueeStartX}px`;
    marqueeEl.style.top = `${marqueeStartY}px`;
    marqueeEl.style.width = "0px";
    marqueeEl.style.height = "0px";

    e.preventDefault(); // suppress text selection during drag
  });

  document.addEventListener("mousemove", (e) => {
    if (!marqueeActive || !marqueeEl) return;

    const rect = driveMain.getBoundingClientRect();
    const currentX = e.clientX - rect.left + driveMain.scrollLeft;
    const currentY = e.clientY - rect.top + driveMain.scrollTop;

    const left = Math.min(marqueeStartX, currentX);
    const top = Math.min(marqueeStartY, currentY);
    const width = Math.abs(currentX - marqueeStartX);
    const height = Math.abs(currentY - marqueeStartY);

    marqueeEl.style.left = `${left}px`;
    marqueeEl.style.top = `${top}px`;
    marqueeEl.style.width = `${width}px`;
    marqueeEl.style.height = `${height}px`;

    // Convert the marquee (in driveMain-internal coords) back to viewport
    // coords for hit-testing against getBoundingClientRect()
    const marqueeViewport = {
      left: left + rect.left - driveMain.scrollLeft,
      top: top + rect.top - driveMain.scrollTop,
      right: left + width + rect.left - driveMain.scrollLeft,
      bottom: top + height + rect.top - driveMain.scrollTop,
    };

    const cards = driveMain.querySelectorAll("[data-item-path]");
    cards.forEach((card) => {
      const cr = card.getBoundingClientRect();
      const intersects = !(
        cr.right < marqueeViewport.left ||
        cr.left > marqueeViewport.right ||
        cr.bottom < marqueeViewport.top ||
        cr.top > marqueeViewport.bottom
      );
      const path = card.getAttribute("data-item-path");
      const wasInInitial = marqueeInitialSelection.has(path);
      const shouldBeSelected = marqueeAdditive
        ? wasInInitial || intersects
        : intersects;

      if (shouldBeSelected && !selectedItems.has(path)) {
        selectedItems.add(path);
        card.classList.add("ring-2", "ring-blue-500", "bg-blue-50");
      } else if (!shouldBeSelected && selectedItems.has(path) && !wasInInitial) {
        selectedItems.delete(path);
        card.classList.remove("ring-2", "ring-blue-500", "bg-blue-50");
      }
    });
  });

