---
import { OrganizationSwitcher } from "@clerk/astro/components";
---

<div
  class="flex relative h-[calc(100vh-73px)] w-full overflow-hidden bg-slate-50/50"
>
  <!-- Mobile Overlay -->
  <div
    id="mobile-overlay"
    class="absolute inset-0 bg-slate-900/20 backdrop-blur-sm z-30 hidden sm:hidden opacity-0 transition-opacity duration-300"
  >
  </div>

  <aside
    id="mobile-sidebar"
    class="w-64 p-6 flex flex-col border-r border-slate-200/60 bg-white shadow-[4px_0_12px_-4px_rgba(0,0,0,0.1)] z-40 absolute inset-y-0 left-0 -translate-x-full sm:translate-x-0 sm:relative sm:shadow-[2px_0_8px_-4px_rgba(0,0,0,0.05)] transition-transform duration-300 ease-in-out"
  >
    <div class="mb-6">
      <p
        class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-3 mt-1"
      >
        Workspace
      </p>
      <OrganizationSwitcher
        hidePersonal={false}
        appearance={{
          elements: {
            organizationSwitcherTrigger:
              "w-full justify-start border border-gray-200 bg-white shadow-sm rounded-lg py-2 px-3",
          },
        }}
      />
    </div>

    <div class="space-y-2 mb-8">
      <button
        id="new-file-btn"
        class="flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 active:scale-[0.98] shadow-md shadow-blue-600/20 rounded-xl px-4 py-2.5 transition-all text-sm font-semibold text-white w-full"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
        </svg>
        Upload File
      </button>
      <button
        id="new-folder-btn"
        class="flex items-center justify-center gap-2 bg-white border border-slate-200 hover:border-slate-300 hover:bg-slate-50 active:scale-[0.98] shadow-sm rounded-xl px-4 py-2.5 transition-all text-sm font-medium text-slate-700 w-full"
      >
        <svg
          class="w-4 h-4 text-slate-500"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
          ></path>
        </svg>
        New Folder
      </button>
      <input type="file" id="file-input" class="hidden" multiple />
    </div>

    <div id="team-section" class="flex-1 overflow-y-auto hidden">
      <p
        class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-3 mt-4"
      >
        Team Access
      </p>
      <ul id="team-members-list" class="space-y-3"></ul>
    </div>
  </aside>

  <main
    id="drive-main"
    class="flex-1 relative p-8 overflow-y-auto transition-colors"
  >
    <div
      id="drag-overlay"
      class="absolute inset-4 rounded-2xl border-2 border-blue-400 border-dashed bg-blue-50/95 z-50 flex items-center justify-center hidden pointer-events-none transition-all"
    >
      <div class="text-center">
        <p class="text-2xl font-semibold text-blue-700">
          Drop to upload to this folder
        </p>
      </div>
    </div>

    <div
      class="flex justify-between items-end mb-8 border-b border-gray-100 pb-4"
    >
      <div class="flex items-center">
        <button
          id="mobile-menu-btn"
          class="sm:hidden p-2 -ml-2 mr-2 text-slate-500 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-colors"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
        <nav
          id="breadcrumbs"
          class="flex flex-wrap items-center gap-2 text-xl font-semibold text-gray-800 tracking-tight"
        >
        </nav>
      </div>
      <span
        id="upload-status"
        class="text-sm font-medium text-blue-600 bg-blue-50 px-3 py-1 rounded-full hidden"
        >Processing...</span
      >
    </div>

    <div id="file-list-container" class="space-y-8">
      <p class="text-slate-400 text-sm flex items-center gap-2 mb-8">
        <svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24"
          ><circle
            class="opacity-25"
            cx="12"
            cy="12"
            r="10"
            stroke="currentColor"
            stroke-width="4"></circle><path
            class="opacity-75"
            fill="currentColor"
            d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
          ></path>
        </svg> Loading...
      </p>
    </div>

    <div
      id="context-menu"
      class="hidden fixed z-[100] w-56 bg-white/95 backdrop-blur-xl border border-slate-200/60 rounded-xl shadow-[0_8px_30px_rgb(0,0,0,0.12)] py-1.5 overflow-hidden ring-1 ring-black/5"
    >
      <button
        id="cm-rename"
        class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-colors flex items-center gap-2"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
          ></path>
        </svg>
        Rename
      </button>
      <button
        id="cm-download"
        class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-colors flex items-center gap-2"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
          ></path>
        </svg>
        Download
      </button>
      <div class="border-t border-gray-100 my-1"></div>
      <button
        id="cm-delete"
        class="w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors flex items-center gap-2 font-medium"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
          ></path>
        </svg>
        Delete
      </button>
    </div>
  </main>
</div>

<!-- Custom Modal Overlay -->
<div
  id="custom-modal"
  class="fixed inset-0 z-[200] hidden items-center justify-center bg-slate-900/40 backdrop-blur-sm transition-opacity opacity-0"
>
  <div
    class="bg-white rounded-2xl shadow-2xl w-full max-w-sm overflow-hidden transform scale-95 transition-transform duration-200 border border-slate-100"
    id="modal-content"
  >
    <div
      class="px-5 py-4 border-b border-slate-100 flex justify-between items-center bg-white"
    >
      <h3 class="text-base font-semibold text-slate-800" id="modal-title">
        Title
      </h3>
      <button
        id="modal-close"
        class="text-slate-400 hover:text-slate-600 transition-colors rounded-full hover:bg-slate-100 p-1"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <div class="px-5 py-5 bg-white">
      <p id="modal-message" class="text-sm text-slate-600 mb-4 hidden"></p>
      <input
        type="text"
        id="modal-input"
        class="w-full px-3 py-2 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all hidden text-sm"
      />
    </div>
    <div
      class="px-5 py-3 bg-slate-50/50 border-t border-slate-100 flex justify-end gap-2"
      id="modal-actions-container"
    >
      <button
        id="modal-cancel"
        class="px-3 py-1.5 text-sm font-medium text-slate-600 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 hover:text-slate-900 transition-colors shadow-sm"
        >Cancel</button
      >
      <button
        id="modal-confirm"
        class="px-3 py-1.5 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors shadow-sm shadow-blue-600/20"
        >Confirm</button
      >
    </div>
  </div>
</div>

<script>
  import { getSupabaseClient } from "../lib/supabase";

  let currentPath = [];
  let activeWorkspaceId = null; // Track this to prevent unnecessary path resets

  const container = document.getElementById("file-list-container");
  const driveMain = document.getElementById("drive-main");
  const dragOverlay = document.getElementById("drag-overlay");
  const newFileBtn = document.getElementById("new-file-btn");
  const newFolderBtn = document.getElementById("new-folder-btn");
  const fileInput = document.getElementById("file-input");
  const uploadStatus = document.getElementById("upload-status");
  const breadcrumbsNav = document.getElementById("breadcrumbs");
  const teamSection = document.getElementById("team-section");
  const teamMembersList = document.getElementById("team-members-list");

  // --- Custom Modal System ---
  const modal = document.getElementById("custom-modal");
  const modalContent = document.getElementById("modal-content");
  const modalTitle = document.getElementById("modal-title");
  const modalMessage = document.getElementById("modal-message");
  const modalInput = document.getElementById("modal-input");
  const btnCancel = document.getElementById("modal-cancel");
  const btnConfirm = document.getElementById("modal-confirm");
  const btnClose = document.getElementById("modal-close");

  const mobileSidebar = document.getElementById("mobile-sidebar");
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileOverlay = document.getElementById("mobile-overlay");

  function toggleMobileMenu(forceClose = false) {
    if (!mobileSidebar) return;
    const isClosed = mobileSidebar.classList.contains("-translate-x-full");
    if (forceClose || !isClosed) {
      mobileSidebar.classList.add("-translate-x-full");
      mobileOverlay.classList.remove("opacity-100");
      setTimeout(() => mobileOverlay.classList.add("hidden"), 300);
    } else {
      mobileOverlay.classList.remove("hidden");
      setTimeout(() => {
        mobileOverlay.classList.add("opacity-100");
        mobileSidebar.classList.remove("-translate-x-full");
      }, 10);
    }
  }

  if (mobileMenuBtn && mobileOverlay) {
    mobileMenuBtn.addEventListener("click", () => toggleMobileMenu());
    mobileOverlay.addEventListener("click", () => toggleMobileMenu(true));
  }

  function showModal(options) {
    return new Promise((resolve) => {
      modalTitle.textContent = options.title;

      if (options.message) {
        modalMessage.textContent = options.message;
        modalMessage.classList.remove("hidden");
      } else {
        modalMessage.classList.add("hidden");
      }

      if (options.type === "prompt") {
        modalInput.value = options.defaultValue || "";
        modalInput.classList.remove("hidden");
        setTimeout(() => modalInput.focus(), 100);
      } else {
        modalInput.classList.add("hidden");
      }

      if (options.confirmClass) {
        btnConfirm.className = options.confirmClass;
      } else {
        btnConfirm.className =
          "px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors shadow-sm shadow-blue-600/20";
      }

      btnConfirm.textContent = options.confirmText || "Confirm";

      modal.classList.remove("hidden", "pointer-events-none");
      modal.classList.add("flex");

      // small delay for transition
      setTimeout(() => {
        modal.classList.remove("opacity-0");
        modalContent.classList.remove("scale-95");
      }, 10);

      const cleanup = () => {
        modal.classList.add("opacity-0");
        modalContent.classList.add("scale-95");
        modal.classList.add("pointer-events-none");
        setTimeout(() => {
          modal.classList.add("hidden");
          modal.classList.remove("flex");
        }, 200);

        btnConfirm.removeEventListener("click", onConfirm);
        btnCancel.removeEventListener("click", onCancel);
        btnClose.removeEventListener("click", onCancel);
        modalInput.removeEventListener("keyup", onKeyup);
      };

      const onConfirm = () => {
        cleanup();
        resolve(options.type === "prompt" ? modalInput.value : true);
      };

      const onCancel = () => {
        cleanup();
        resolve(options.type === "prompt" ? null : false);
      };

      const onKeyup = (e) => {
        if (e.key === "Enter") onConfirm();
        if (e.key === "Escape") onCancel();
      };

      btnConfirm.addEventListener("click", onConfirm);
      btnCancel.addEventListener("click", onCancel);
      btnClose.addEventListener("click", onCancel);
      if (options.type === "prompt") {
        modalInput.addEventListener("keyup", onKeyup);
      }
    });
  }

  function getActiveWorkspaceId() {
    return window.Clerk.organization?.id || window.Clerk.user.id;
  }

  function checkAdminPrivileges() {
    // 1. If no organization is active, you are in your Personal Drive (always owner/admin)
    if (!window.Clerk.organization) return true;

    // 2. Find the membership for the current active organization
    const activeOrgId = window.Clerk.organization.id;
    const membership = window.Clerk.user.organizationMemberships.find(
      (m) => m.organization.id === activeOrgId
    );

    // 3. Clerk roles usually look like 'org:admin' or 'admin'
    const role = membership?.role;
    return role === "admin" || role === "org:admin";
  }

  const waitForClerk = setInterval(() => {
    if (window.Clerk && window.Clerk.loaded) {
      clearInterval(waitForClerk);
      if (window.Clerk.user) {
        activeWorkspaceId = getActiveWorkspaceId();
        refreshUI(true);

        window.Clerk.addListener(() => {
          if (!window.Clerk.user) {
            window.location.href = "/login";
            return;
          }
          const newWorkspaceId = getActiveWorkspaceId();
          if (newWorkspaceId !== activeWorkspaceId) {
            // ONLY reset path if the user actually switched teams
            activeWorkspaceId = newWorkspaceId;
            refreshUI(true);
          } else {
            // Background token refresh? Just update team members list invisibly
            loadTeamMembers();
          }
        });
      } else {
        window.location.href = "/login";
      }
    }
  }, 100);

  function refreshUI(resetPath = false) {
    if (resetPath) currentPath = [];
    renderBreadcrumbs();
    loadFiles();
    loadTeamMembers();
  }

  // --- Move to Ancestor Logic ---
  async function moveItemToAncestor(e, ancestorIndex) {
    const dragData = JSON.parse(
      e.dataTransfer.getData("application/json") || "{}"
    );
    const oldPath = dragData.path;
    const isFolder = dragData.type === "folder";

    if (!oldPath) return;

    const workspaceId = getActiveWorkspaceId();
    // Calculate new path: Root + currentPath up to the ancestorIndex + item name
    const ancestorPathSlice = currentPath.slice(0, ancestorIndex + 1);
    const destinationPrefix =
      ancestorPathSlice.length > 0 ? ancestorPathSlice.join("/") + "/" : "";
    const itemName = oldPath.split("/").pop();
    const newPath = `${workspaceId}/${destinationPrefix}${itemName}`;

    if (oldPath === newPath) return; // Dropped on self

    uploadStatus.classList.remove("hidden");
    uploadStatus.textContent = isFolder ? "Moving folder..." : "Moving file...";

    const supabase = await getSupabaseClient();

    if (isFolder) {
      // Supabase doesn't have a "move folder" command.
      // We must list all files with the folder prefix and move them one by one.
      const { data: filesToMove } = await supabase.storage
        .from("user_files")
        .list(oldPath, { limit: 100 });

      if (filesToMove) {
        for (const file of filesToMove) {
          const fileOldPath = `${oldPath}/${file.name}`;
          const fileNewPath = `${newPath}/${file.name}`;
          await supabase.storage
            .from("user_files")
            .move(fileOldPath, fileNewPath);
        }
      }
    } else {
      // Simple file move
      await supabase.storage.from("user_files").move(oldPath, newPath);
    }

    uploadStatus.classList.add("hidden");
    refreshUI(); // Reload to show the item has left the current view
  }

  // --- Enhanced Breadcrumb Logic with Drop Targets ---
  function renderBreadcrumbs() {
    const rootName = window.Clerk.organization?.name || "Personal Drive";
    breadcrumbsNav.innerHTML = "";

    // 1. Root Breadcrumb (Home)
    const rootBtn = document.createElement("button");
    rootBtn.className =
      "hover:text-blue-600 transition-colors truncate max-w-[200px] text-left px-1 rounded hover:bg-gray-100";
    rootBtn.textContent = rootName;
    rootBtn.onclick = () => {
      currentPath = [];
      refreshUI();
    };

    // Drop logic for Root
    rootBtn.ondragover = (e) => {
      e.preventDefault();
      rootBtn.classList.add("bg-blue-100", "text-blue-700");
    };
    rootBtn.ondragleave = () =>
      rootBtn.classList.remove("bg-blue-100", "text-blue-700");
    rootBtn.ondrop = (e) => {
      e.preventDefault();
      rootBtn.classList.remove("bg-blue-100", "text-blue-700");
      moveItemToAncestor(e, -1); // -1 signifies the root
    };

    breadcrumbsNav.appendChild(rootBtn);

    // 2. Ancestor Folders
    currentPath.forEach((folder, index) => {
      const separator = document.createElement("span");
      separator.className = "text-gray-400 text-lg mx-1";
      separator.textContent = "/";
      breadcrumbsNav.appendChild(separator);

      const folderBtn = document.createElement("button");
      const isLast = index === currentPath.length - 1;

      folderBtn.className = isLast
        ? "text-gray-800 font-bold px-1"
        : "hover:text-blue-600 transition-colors px-1 rounded hover:bg-gray-100";

      folderBtn.textContent = folder;
      folderBtn.onclick = () => {
        currentPath = currentPath.slice(0, index + 1);
        refreshUI();
      };

      // Only allow dropping on ANCESTORS (not the current folder itself)
      if (!isLast) {
        folderBtn.ondragover = (e) => {
          e.preventDefault();
          folderBtn.classList.add("bg-blue-100", "text-blue-700");
        };
        folderBtn.ondragleave = () =>
          folderBtn.classList.remove("bg-blue-100", "text-blue-700");
        folderBtn.ondrop = (e) => {
          e.preventDefault();
          folderBtn.classList.remove("bg-blue-100", "text-blue-700");
          moveItemToAncestor(e, index);
        };
      }

      breadcrumbsNav.appendChild(folderBtn);
    });
  }

  async function loadTeamMembers() {
    if (!window.Clerk.organization) return teamSection.classList.add("hidden");
    teamSection.classList.remove("hidden");
    const { data: memberships } =
      await window.Clerk.organization.getMemberships();
    teamMembersList.innerHTML = "";

    memberships.forEach((member) => {
      const isSelf = member.publicUserData.userId === window.Clerk.user.id;
      const isAdmin = member.role === "org:admin";
      teamMembersList.innerHTML += `
        <li class="flex items-center gap-3">
          <img src="${
            member.publicUserData.imageUrl
          }" class="w-7 h-7 rounded-full border border-gray-200">
          <div class="flex-1 min-w-0">
            <p class="text-xs font-medium text-gray-700 truncate">${
              member.publicUserData.firstName
            } ${isSelf ? "(You)" : ""}</p>
            <span class="text-[9px] font-bold uppercase px-1.5 py-0.5 rounded ${
              isAdmin ? "text-blue-600 bg-blue-50" : "text-gray-500 bg-gray-100"
            }">${isAdmin ? "Admin" : "Viewer"}</span>
          </div>
        </li>`;
    });
  }

  const contextMenu = document.getElementById("context-menu");
  let currentTargetItem = null; // Stores { path, name, type }

  // 1. Listen for right-clicks on items
  document.addEventListener("contextmenu", (e) => {
    // Check if we clicked an item card
    const itemCard = e.target.closest("[data-item-path]");
    if (!itemCard) {
      hideContextMenu();
      return;
    }

    e.preventDefault(); // Prevent native browser menu

    const isAdmin = checkAdminPrivileges();
    currentTargetItem = {
      path: itemCard.getAttribute("data-item-path"),
      name: itemCard.getAttribute("data-item-name"),
      type: itemCard.getAttribute("data-item-type"),
    };

    // Show/Hide buttons based on type and permissions
    document
      .getElementById("cm-download")
      .classList.toggle("hidden", currentTargetItem.type === "folder");
    document.getElementById("cm-rename").classList.toggle("hidden", !isAdmin);
    document.getElementById("cm-delete").classList.toggle("hidden", !isAdmin);

    // Position and show menu
    contextMenu.style.top = `${e.clientY}px`;
    contextMenu.style.left = `${e.clientX}px`;
    contextMenu.classList.remove("hidden");
  });

  // 2. Hide menu on click outside
  window.addEventListener("click", hideContextMenu);
  function hideContextMenu() {
    contextMenu.classList.add("hidden");
  }

  // 3. Bind Menu Actions
  document.getElementById("cm-rename").onclick = () => {
    if (currentTargetItem)
      window.triggerRename(
        currentTargetItem.path,
        currentTargetItem.name,
        currentTargetItem.type
      );
  };
  document.getElementById("cm-download").onclick = () => {
    if (currentTargetItem)
      window.triggerDownload(currentTargetItem.path, currentTargetItem.name);
  };
  document.getElementById("cm-delete").onclick = () => {
    if (currentTargetItem)
      window.triggerDelete(currentTargetItem.path, currentTargetItem.type);
  };

  newFileBtn.addEventListener("click", () => fileInput.click());
  fileInput.addEventListener("change", (e) => handleUpload(e.target.files));

  newFolderBtn.addEventListener("click", async () => {
    const folderName = await showModal({
      type: "prompt",
      title: "New Folder",
      confirmText: "Create",
    });
    if (!folderName) return;
    const workspaceId = getActiveWorkspaceId();
    const prefix = currentPath.length > 0 ? currentPath.join("/") + "/" : "";
    const dummyPath = `${workspaceId}/${prefix}${folderName}/.emptyFolderPlaceholder`;
    const supabase = await getSupabaseClient();
    await supabase.storage.from("user_files").upload(dummyPath, new Blob([""]));
    loadFiles();
  });

  async function handleUpload(files) {
    if (!files || files.length === 0) return;
    const workspaceId = getActiveWorkspaceId();
    const prefix = currentPath.length > 0 ? currentPath.join("/") + "/" : "";
    const supabase = await getSupabaseClient();

    uploadStatus.classList.remove("hidden");
    uploadStatus.textContent = "Uploading...";

    for (const file of files) {
      const filePath = `${workspaceId}/${prefix}${Date.now()}_${file.name}`;
      await supabase.storage.from("user_files").upload(filePath, file);
    }

    uploadStatus.classList.add("hidden");
    loadFiles();
  }

  // --- Targeted Drag & Drop Logic ---
  let dragCounter = 0;

  driveMain.addEventListener("dragenter", (e) => {
    e.preventDefault();
    // Only show the big upload overlay if we are dragging actual files from the OS
    if (e.dataTransfer.types.includes("Files")) {
      dragCounter++;
      dragOverlay.classList.remove("hidden");
    }
  });

  driveMain.addEventListener("dragleave", (e) => {
    e.preventDefault();
    if (e.dataTransfer.types.includes("Files")) {
      dragCounter--;
      if (dragCounter === 0) dragOverlay.classList.add("hidden");
    }
  });

  driveMain.addEventListener("dragover", (e) => e.preventDefault());

  driveMain.addEventListener("drop", (e) => {
    e.preventDefault();
    dragCounter = 0;
    dragOverlay.classList.add("hidden");

    // Check if it's an external file upload
    if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
      handleUpload(e.dataTransfer.files);
    }
  });

  async function loadFiles(searchQuery = "") {
    const workspaceId = getActiveWorkspaceId();
    const supabase = await getSupabaseClient();
    const isAdmin = checkAdminPrivileges();
    const prefix = currentPath.length > 0 ? currentPath.join("/") + "/" : "";

    container.innerHTML = '<p class="text-gray-400 text-sm">Loading...</p>';

    let folders = [];
    let files = [];

    if (searchQuery) {
      // Recursive search across the workspace
      let allFiles = [];
      const queue = [workspaceId];

      while (queue.length > 0) {
        const currentDir = queue.shift();
        const { data, error } = await supabase.storage
          .from("user_files")
          .list(currentDir, { limit: 100 });

        if (data) {
          for (const item of data) {
            if (item.name === ".emptyFolderPlaceholder") continue;

            if (!item.id) {
              // it's a folder, enqueue it
              queue.push(`${currentDir}/${item.name}`);
            } else {
              // it's a file, check if it matches search
              const cleanName = item.name.replace(/^\d+_/, "");
              if (cleanName.toLowerCase().includes(searchQuery.toLowerCase())) {
                allFiles.push({
                  ...item,
                  name: item.name,
                  displayPath: `${currentDir.replace(
                    workspaceId,
                    ""
                  )}/${cleanName}`.substring(1),
                  fullPath: `${currentDir}/${item.name}`,
                });
              }
            }
          }
        }
      }
      files = allFiles;
      // We do not show folders in search results per request
      folders = [];

      if (files.length === 0) {
        return (container.innerHTML = `<div class="py-10 text-center text-gray-400 text-sm w-full border-2 border-dashed border-gray-100 rounded-xl">
            <svg class="w-12 h-12 mx-auto mb-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            No files match your search "${searchQuery}".
          </div>`);
      }
    } else {
      // Normal single-directory load
      const searchPath = `${workspaceId}${
        prefix ? "/" + prefix.slice(0, -1) : ""
      }`;
      const { data, error } = await supabase.storage
        .from("user_files")
        .list(searchPath, {
          limit: 100,
          sortBy: { column: "created_at", order: "desc" },
        });

      if (error)
        return (container.innerHTML =
          '<p class="text-red-500 text-sm">Failed to load folder.</p>');

      const validItems =
        data?.filter((f) => !f.name.endsWith(".emptyFolderPlaceholder")) || [];

      if (validItems.length === 0) {
        return (container.innerHTML =
          '<div class="py-10 text-center text-gray-400 text-sm w-full border-2 border-dashed border-gray-100 rounded-xl">This folder is empty.</div>');
      }

      folders = validItems.filter((item) => !item.id);
      files = validItems
        .filter((item) => item.id)
        .map((f) => ({ ...f, fullPath: `${searchPath}/${f.name}` }));
    }

    container.innerHTML = "";

    // Render Folders Section
    if (folders.length > 0) {
      const folderSection = document.createElement("div");
      folderSection.innerHTML = `<h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Folders</h3>`;
      const folderGrid = document.createElement("div");
      folderGrid.className =
        "grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4";

      folders.forEach((folder) => {
        const folderDisplayName = folder.name.replace(/\/$/, "");
        const folderFullPath = searchQuery
          ? `${workspaceId}/${folder.name}`
          : `${workspaceId}/${prefix}${folder.name}`;

        const card = document.createElement("div");
        card.className =
          "group flex items-center gap-3 p-3 rounded-xl border border-gray-200 bg-gray-50 hover:bg-blue-50 hover:border-blue-300 cursor-pointer transition-colors";
        card.setAttribute("data-item-path", folderFullPath);
        card.setAttribute("data-item-name", folderDisplayName);
        card.setAttribute("data-item-type", "folder");
        card.draggable = isAdmin;
        card.ondragstart = (e) => {
          e.dataTransfer.setData(
            "application/json",
            JSON.stringify({ path: folderFullPath, type: "folder" })
          );
        };

        // Folder Drop Logic
        card.ondragover = (e) => {
          e.preventDefault();
          card.classList.add("ring-2", "ring-blue-400", "bg-blue-100");
        };
        card.ondragleave = () =>
          card.classList.remove("ring-2", "ring-blue-400", "bg-blue-100");
        card.ondrop = (e) => {
          e.preventDefault();
          card.classList.remove("ring-2", "ring-blue-400", "bg-blue-100");
          window.moveFileToFolder(e, folderDisplayName);
        };

        card.onclick = () => {
          if (searchQuery) {
            const globalSearch = document.getElementById("global-search");
            if (globalSearch) globalSearch.value = "";
            currentPath = folderDisplayName.split("/").filter(Boolean);
          } else {
            currentPath.push(folderDisplayName);
          }
          refreshUI();
        };
        card.innerHTML = `
          <svg class="w-10 h-10 text-blue-400/80 pointer-events-none drop-shadow-sm" fill="currentColor" viewBox="0 0 20 20"><path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z"></path></svg>
          <span class="text-sm font-semibold text-slate-700 truncate pointer-events-none group-hover:text-blue-600 transition-colors" title="${folderDisplayName}">${folderDisplayName}</span>
        `;
        folderGrid.appendChild(card);
      });
      folderSection.appendChild(folderGrid);
      container.appendChild(folderSection);
    }

    // Render Files Section
    if (files.length > 0) {
      const fileSection = document.createElement("div");
      fileSection.innerHTML = `<h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Files</h3>`;
      const fileGrid = document.createElement("div");
      fileGrid.className =
        "grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-5";

      files.forEach((file) => {
        const fullPath = file.fullPath;
        const baseName = file.name.split("/").pop();
        const cleanFileName = baseName.replace(/^\d+_/, "");
        const displayName = searchQuery ? file.displayPath : cleanFileName;

        const card = document.createElement("div");
        card.setAttribute("data-item-path", fullPath);
        card.setAttribute("data-item-name", cleanFileName);
        card.setAttribute("data-item-type", "file");
        // File Drag Logic
        card.draggable = isAdmin; // Only allow admins to drag files
        card.ondragstart = (e) => {
          e.dataTransfer.setData(
            "application/json",
            JSON.stringify({ path: fullPath, type: "file" })
          );
        };
        card.className = `group flex flex-col justify-between p-4 rounded-xl border border-gray-200 bg-white hover:border-blue-300 hover:shadow-md transition-all ${
          isAdmin ? "cursor-grab active:cursor-grabbing" : ""
        }`;

        card.innerHTML = `
          <div class="mb-4 flex flex-col items-center cursor-pointer" onclick="window.triggerPreview('${fullPath}')">
            <div class="w-12 h-12 mb-3 text-gray-400 group-hover:text-blue-500 transition-colors pointer-events-none">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
            </div>
            <span class="block w-full text-xs font-semibold text-gray-700 truncate text-center pointer-events-none" title="${displayName}">${displayName}</span>
          </div>
          <div class="flex justify-between items-center border-t border-gray-100 pt-3 mt-auto">
            ${
              isAdmin
                ? `<button class="text-[11px] font-medium text-gray-500 hover:text-red-600 px-1" onclick="window.triggerDelete('${fullPath}', 'file')">Delete</button>`
                : `<span class="text-[10px] font-bold uppercase text-gray-300 tracking-wider">Read Only</span>`
            }
            <button class="text-gray-400 hover:text-blue-600 ml-auto" onclick="window.triggerDownload('${fullPath}', '${cleanFileName}')"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg></button>
          </div>
        `;
        fileGrid.appendChild(card);
      });
      fileSection.appendChild(fileGrid);
      container.appendChild(fileSection);
    }
  }

  // File Moving Logic
  window.moveFileToFolder = async (e, targetFolderName) => {
    // 1. Get the JSON data we set in ondragstart
    const dragData = JSON.parse(
      e.dataTransfer.getData("application/json") || "{}"
    );
    const oldPath = dragData.path;

    if (!oldPath) return;

    const fileName = oldPath.split("/").pop();
    const workspaceId = getActiveWorkspaceId();
    const prefix = currentPath.length > 0 ? currentPath.join("/") + "/" : "";
    const newPath = `${workspaceId}/${prefix}${targetFolderName}/${fileName}`;

    // Prevent moving a folder into itself
    if (
      oldPath === newPath ||
      oldPath === `${workspaceId}/${prefix}${targetFolderName}`
    )
      return;

    uploadStatus.classList.remove("hidden");
    uploadStatus.textContent = "Moving...";

    const supabase = await getSupabaseClient();
    await supabase.storage.from("user_files").move(oldPath, newPath);

    uploadStatus.classList.add("hidden");
    loadFiles();
  };

  window.triggerPreview = async (path) => {
    const supabase = await getSupabaseClient();
    const { data } = await supabase.storage
      .from("user_files")
      .createSignedUrl(path, 60);
    window.open(data.signedUrl, "_blank");
  };

  window.triggerDownload = async (path, fileName) => {
    const supabase = await getSupabaseClient();
    const { data } = await supabase.storage
      .from("user_files")
      .createSignedUrl(path, 60);
    const link = document.createElement("a");
    link.href = data.signedUrl;
    link.download = fileName;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  };

  window.triggerRename = async (path, oldName, type) => {
    const newName = await showModal({
      type: "prompt",
      title: `Rename ${type}`,
      defaultValue: oldName,
      confirmText: "Rename",
    });

    if (!newName || newName === oldName) return;

    const supabase = await getSupabaseClient();
    uploadStatus.classList.remove("hidden");
    uploadStatus.textContent = "Renaming...";

    const newPath = path.slice(0, -oldName.length) + newName;

    if (type === "folder") {
      const { data: filesToMove } = await supabase.storage
        .from("user_files")
        .list(path, { limit: 100 });

      if (filesToMove && filesToMove.length > 0) {
        for (const file of filesToMove) {
          const fileOldPath = `${path}/${file.name}`;
          const fileNewPath = `${newPath}/${file.name}`;
          await supabase.storage
            .from("user_files")
            .move(fileOldPath, fileNewPath);
        }
      } else {
        await supabase.storage
          .from("user_files")
          .move(
            `${path}/.emptyFolderPlaceholder`,
            `${newPath}/.emptyFolderPlaceholder`
          );
      }
    } else {
      await supabase.storage.from("user_files").move(path, newPath);
    }

    uploadStatus.classList.add("hidden");
    loadFiles();
  };

  window.triggerDelete = async (path, type) => {
    const confirmed = await showModal({
      type: "confirm",
      title: `Delete ${type || "item"}`,
      message: `Are you sure you want to delete this ${
        type || "item"
      }? This action cannot be undone.`,
      confirmText: "Delete",
      confirmClass:
        "px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 transition-colors shadow-sm shadow-red-600/20",
    });

    if (!confirmed) return;
    const supabase = await getSupabaseClient();
    uploadStatus.classList.remove("hidden");
    uploadStatus.textContent = "Deleting...";

    if (type === "folder") {
      const { data: filesToDelete } = await supabase.storage
        .from("user_files")
        .list(path, { limit: 100 });

      if (filesToDelete && filesToDelete.length > 0) {
        const pathsToRemove = filesToDelete.map(
          (file) => `${path}/${file.name}`
        );
        await supabase.storage
          .from("user_files")
          .remove([...pathsToRemove, path, `${path}/.emptyFolderPlaceholder`]);
      } else {
        await supabase.storage
          .from("user_files")
          .remove([path, `${path}/.emptyFolderPlaceholder`]);
      }
    } else {
      await supabase.storage.from("user_files").remove([path]);
    }

    uploadStatus.classList.add("hidden");
    loadFiles();
  };

  // Search filtering logic
  const globalSearch = document.getElementById("global-search");
  let searchTimeout;
  if (globalSearch) {
    globalSearch.addEventListener("input", (e) => {
      const query = (e.target.value || "").trim().toLowerCase();
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        loadFiles(query);
      }, 300);
    });
  }
</script>
