---
import { SignedIn, SignedOut, UserButton } from "@clerk/astro/components";
---

<div class="fixed top-0 left-0 w-full z-[100] px-4 pt-4 pointer-events-none">
  <header
    class="pointer-events-auto max-w-7xl mx-auto h-[73px] flex items-center justify-center backdrop-blur-md bg-white/20 border border-white/10 shadow-lg rounded-full px-6"
  >
    <div class="grid grid-cols-2 md:grid-cols-3 items-center w-full px-6">
      <a href="/" class="flex items-center gap-3 group justify-self-start">
        <div
          class="w-9 h-9 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center text-white shadow-lg group-hover:scale-105 transition-transform duration-300 border border-white/30"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path>
          </svg>
        </div>
        <h1 class="text-xl font-bold tracking-tight text-white drop-shadow">
          Stratos
        </h1>
      </a>

      <div class="justify-self-center w-full max-w-md hidden md:block">
        <SignedIn>
          <div class="relative w-full">
            <svg class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <input
              id="global-search"
              type="text"
              placeholder="Search files across your drive..."
              class="w-full bg-white/10 border border-white/20 backdrop-blur-sm rounded-full py-2 pl-9 pr-4 text-sm focus:ring-2 focus:ring-white/30 focus:border-white/40 focus:bg-white/20 transition-all outline-none text-white placeholder:text-white/40"
            />
          </div>
        </SignedIn>
      </div>

      <nav class="flex items-center gap-4 justify-self-end">
        <SignedOut>
          <a href="/login" class="text-sm font-semibold text-white/80 hover:text-white px-3 py-2 transition-colors whitespace-nowrap">Log in</a>
          <a href="/register" class="text-sm font-semibold text-white bg-white/20 hover:bg-white/30 backdrop-blur-sm border border-white/30 px-5 py-2 rounded-full transition-all active:scale-95 whitespace-nowrap">Get Started</a>
        </SignedOut>
        
        <SignedIn>
          <a href="/drive" class="text-sm font-semibold text-white/80 hover:text-white px-3 py-2 transition-colors hidden sm:block">Go to Drive</a>
          <div class="p-1 rounded-full border border-white/20 flex items-center justify-center">
            <UserButton
              appearance={{
                elements: {
                  userButtonAvatarBox: "w-8 h-8 rounded-full border border-white shadow-sm",
                },
              }}
            />
          </div>
        </SignedIn>
      </nav>
    </div>
  </header>
</div>