---
import { SignedIn, SignedOut, UserButton } from "@clerk/astro/components";
import { dark } from "@clerk/themes";

interface Props {
  isHome?: boolean;
}

const { isHome = false } = Astro.props;
const pathname = Astro.url.pathname;
const isDrivePage = pathname === "/drive" || pathname.startsWith("/drive/");
---

<div class="fixed top-0 left-0 w-full z-[100] px-4 pt-4 pointer-events-none">
  <header
    class={`pointer-events-auto mx-auto flex items-center justify-center backdrop-blur-md border shadow-lg rounded-full h-[64px] max-w-7xl w-full px-6 transition-all duration-300 ease-in-out ${
      isDrivePage ? 'border-indigo-200/50' : 'border-black/10'
    }`}
    style={{
      backgroundColor: isDrivePage 
      ? 'rgba(0,0,0,00)'
        : 'rgba(255, 255, 255, 0.1)'
    }}
  >
    <div class="grid grid-cols-2 md:grid-cols-3 items-center w-full px-2">

      <a href="/" class="flex items-center gap-3 group transition-all">
        <div class="w-9 h-9 rounded-full bg-indigo-100 dark:bg-white/20 backdrop-blur-sm flex items-center justify-center text-indigo-600 dark:text-white shadow-lg border border-indigo-200 dark:border-white/30 transition-all duration-300 group-hover:scale-105 group-hover:-translate-y-0.5 group-hover:shadow-[0_0_0_1px_rgba(99,102,241,0.4),0_8px_32px_rgba(99,102,241,0.25)]">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path>
          </svg>
        </div>
        <h1 class="text-xl font-semibold tracking-tight text-white transition-all duration-300 group-hover:-translate-y-0.5">Stratos</h1>
      </a>

      <div class="justify-self-center w-full max-w-md hidden md:flex items-center justify-center">
        {isDrivePage && (
          <SignedIn>
            <div class="relative w-full">
              <svg class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 dark:text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
              <input
                id="global-search"
                type="text"
                placeholder="Search files..."
                class="w-full bg-black/5 dark:bg-white/10 border border-black/10 dark:border-white/20 backdrop-blur-sm rounded-full py-2 pl-9 pr-4 text-sm focus:ring-2 focus:ring-indigo-400/40 dark:focus:ring-white/30 text-slate-800 dark:text-white outline-none placeholder:text-slate-400 dark:placeholder:text-white/40"
              />
            </div>
          </SignedIn>
        )}

        {!isDrivePage && (
          <div class="flex items-center gap-3 text-white text-sm font-medium select-none">
            <span class="w-px h-4 bg-white/20"></span>
            <span class="tracking-wide">Simple. Fast. Yours.</span>
            <span class="w-px h-4 bg-white/20"></span>
          </div>
        )}
      </div>

      <nav class="flex items-center gap-3 justify-self-end">
        <SignedOut>
          <a href="/login" class="text-sm font-semibold text-white/80 dark:hover:text-white hover:-translate-y-0.5 transition">Log in</a>
          <a href="/register" class="glow-hover text-sm font-semibold text-white bg-indigo-500 hover:bg-indigo-600 dark:bg-white/20 dark:hover:bg-white/30 border border-indigo-500/80 dark:border-white/30 px-5 py-2 rounded-full transition-all active:scale-95 shadow-sm">Get Started</a>
        </SignedOut>

        <SignedIn>
          {!isDrivePage && (
            <a href="/drive" class="text-sm font-semibold text-white/80 hover:text-white px-2 transition-colors">Go to Drive</a>
          )}
          <div class="p-1 rounded-full border border-black/10 dark:border-white/20 flex items-center justify-center">
            <UserButton
              appearance={{
                elements: { userButtonAvatarBox: "w-8 h-8 rounded-full" },
              }}
            />
          </div>
        </SignedIn>

        <button
          id="dark-toggle"
          aria-label="Toggle dark mode"
          class="w-9 h-9 flex items-center justify-center rounded-full bg-black/5 hover:bg-black/10 dark:bg-white/10 dark:hover:bg-white/20 border border-black/10 dark:border-white/20 text-slate-600 dark:text-white transition-all active:scale-95 hover:scale-105"
        >
          <svg id="icon-sun" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"></path>
          </svg>
          <svg id="icon-moon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
          </svg>
        </button>
      </nav>

    </div>
  </header>
</div>

<script>
  const html = document.documentElement;
  const btn = document.getElementById('dark-toggle');
  const sun = document.getElementById('icon-sun');
  const moon = document.getElementById('icon-moon');

  const updateIcons = () => {
    const isDark = html.classList.contains('dark');
    sun?.classList.toggle('hidden', !isDark);
    moon?.classList.toggle('hidden', isDark);
  };

  updateIcons();

  btn?.addEventListener('click', () => {
    const isDark = html.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    updateIcons();
  });
</script>
