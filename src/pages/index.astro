---
import Layout from "../layouts/Layout.astro";
const { isAuthenticated } = Astro.locals.auth();
const ctaUrl = isAuthenticated ? "/drive" : "/register";
const ctaText = isAuthenticated ? "Go to Drive" : "Start for free";
---

<Layout>
  <div
    class="relative overflow-hidden w-full bg-slate-50 min-h-[calc(100vh-73px)] flex flex-col items-center justify-center -mt-[73px] pt-[73px]"
  >
    <!-- Decorative background elements -->
    <div
      class="absolute top-1/4 -left-64 w-96 h-96 bg-indigo-300 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob"
    >
    </div>
    <div
      class="absolute top-1/3 -right-64 w-96 h-96 bg-purple-300 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob animation-delay-2000"
    >
    </div>
    <div
      class="absolute -bottom-32 left-1/2 -translate-x-1/2 w-96 h-96 bg-pink-300 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob animation-delay-4000"
    >
    </div>

    <div
      class="max-w-7xl mx-auto px-6 pt-20 pb-32 relative z-10 text-center flex flex-col items-center"
    >
      <div
        class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white border border-slate-200 shadow-sm mb-8 text-sm font-medium text-slate-600"
      >
        <span class="flex h-2 w-2 relative">
          <span
            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"
          ></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"
          ></span>
        </span>
        Stratos V1 is now live
      </div>

      <h1
        class="text-5xl md:text-7xl font-extrabold tracking-tight text-slate-900 mb-8 max-w-4xl leading-[1.1]"
      >
        Cloud storage that feels <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 via-purple-600 to-pink-500"
          >beautifully simple.</span
        >
      </h1>

      <p
        class="text-lg md:text-xl text-slate-600 mb-12 max-w-2xl leading-relaxed"
      >
        Upload, organize, and share your files seamlessly with your team.
        Experience a robust Drive environment stripped of the clutter.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
        <a
          href={ctaUrl}
          class="inline-flex justify-center items-center gap-2 px-8 py-4 rounded-full text-white bg-slate-900 hover:bg-slate-800 transition-all font-semibold shadow-lg shadow-slate-900/20 hover:shadow-xl hover:-translate-y-0.5 active:scale-95 text-lg"
        >
          {ctaText}
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
          </svg>
        </a>
        <a
          href="/about"
          class="inline-flex justify-center items-center gap-2 px-8 py-4 rounded-full text-slate-700 bg-white border border-slate-200 hover:bg-slate-50 transition-all font-semibold shadow-sm hover:shadow-md hover:-translate-y-0.5 active:scale-95 text-lg"
        >
          Learn more
        </a>
      </div>

      <!-- Feature highlight mock -->
      <div class="mock-wrapper" id="mockWrapper">
        <div class="mock-frame" id="mockFrame">
          <div class="mock-header">
            <div class="mock-dots">
              <div class="dot dot-red"></div>
              <div class="dot dot-yellow"></div>
              <div class="dot dot-green"></div>
            </div>
            <div class="mock-url-bar">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity:0.4">
                <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
              <span>stratos.app/drive</span>
            </div>
          </div>

          <div class="mock-body">
            <div class="mock-sidebar">
              <div class="sidebar-item sidebar-active">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
                My Drive
              </div>
              <div class="sidebar-item">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                Shared
              </div>
              <div class="sidebar-item">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Recent
              </div>
              <div class="sidebar-divider"></div>
              <div class="sidebar-storage">
                <div class="storage-label">Storage</div>
                <div class="storage-bar"><div class="storage-fill"></div></div>
                <div class="storage-text">4.2 GB of 15 GB used</div>
              </div>
            </div>

            <div class="mock-main">
              <div class="mock-toolbar">
                <span class="mock-section-label">My Drive</span>
                <div class="mock-toolbar-actions">
                  <div class="toolbar-btn active-view">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                  </div>
                  <div class="toolbar-btn">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                  </div>
                </div>
              </div>

              <div class="mock-grid">
                <div class="mock-file">
                  <div class="file-icon folder-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                  </div>
                  <div class="file-name">ACM Marketing Graphics</div>
                  <div class="file-meta">24 files</div>
                </div>
                <div class="mock-file">
                  <div class="file-icon folder-icon folder-purple">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                  </div>
                  <div class="file-name">CPSC 491 Progress Reports</div>
                  <div class="file-meta">8 files</div>
                </div>
                <div class="mock-file">
                  <div class="file-icon image-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                  </div>
                  <div class="file-name">tuffy-icon.png</div>
                  <div class="file-meta">2.4 MB</div>
                </div>
                <div class="mock-file">
                  <div class="file-icon doc-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                  </div>
                  <div class="file-name">BIOL-151-Mitosis-Essay.docx</div>
                  <div class="file-meta">128 KB</div>
                </div>
                <div class="mock-file">
                  <div class="file-icon video-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
                  </div>
                  <div class="file-name">GDC-2025-Vlog.mp4</div>
                  <div class="file-meta">84 MB</div>
                </div>
                <div class="mock-file mock-upload">
                  <div class="upload-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                  </div>
                  <div class="file-name" style="color: #6366f1; font-weight:500">Upload file</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="float-card float-card-1" aria-hidden="true">
          <div class="float-icon">✓</div>
          <div>
            <div class="float-title">Synced</div>
            <div class="float-sub">3 files just updated</div>
          </div>
        </div>
        <div class="float-card float-card-2" aria-hidden="true">
          <div class="float-avatar">JD</div>
          <div>
            <div class="float-title">Joel shared a file</div>
            <div class="float-sub">how2getajob.pdf</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</Layout>

<style>
  @keyframes blob {
    0% { transform: translate(0px, 0px) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
    100% { transform: translate(0px, 0px) scale(1); }
  }
  .animate-blob { animation: blob 7s infinite; }
  .animation-delay-2000 { animation-delay: 2s; }
  .animation-delay-4000 { animation-delay: 4s; }

  .mock-wrapper {
    position: relative;
    width: 100%;
    max-width: 900px;
    margin-top: 48px;
  }
  .mock-frame {
    width: 100%;
    border-radius: 16px;
    background: rgba(255,255,255,0.75);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.9);
    box-shadow: 0 0 0 1px rgba(200,200,240,0.3), 0 24px 80px rgba(99,102,241,0.12), 0 8px 32px rgba(0,0,0,0.08);
    overflow: hidden;
    cursor: default;
    will-change: transform;
  }
  .mock-header {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 16px;
    border-bottom: 1px solid rgba(200,200,220,0.3);
    background: rgba(248,247,255,0.6);
  }
  .mock-dots { display: flex; gap: 5px; }
  .dot { width: 10px; height: 10px; border-radius: 50%; }
  .dot-red    { background: #ff5f57; }
  .dot-yellow { background: #ffbd2e; }
  .dot-green  { background: #28c840; }
  .mock-url-bar {
    flex: 1; display: flex; align-items: center; gap: 6px;
    height: 24px; padding: 0 10px;
    background: rgba(255,255,255,0.7);
    border: 1px solid rgba(200,200,220,0.4);
    border-radius: 6px; font-size: 11px; color: #94a3b8;
    max-width: 260px; margin: 0 auto;
  }
  .mock-body { display: flex; height: 320px; }
  .mock-sidebar {
    width: 155px; flex-shrink: 0;
    border-right: 1px solid rgba(200,200,220,0.25);
    padding: 14px 10px;
    display: flex; flex-direction: column; gap: 2px;
    background: rgba(250,249,255,0.5);
  }
  .sidebar-item {
    display: flex; align-items: center; gap: 7px;
    padding: 7px 8px; border-radius: 7px;
    font-size: 12px; color: #64748b; cursor: pointer; transition: all 0.15s;
  }
  .sidebar-item:hover { background: rgba(99,102,241,0.06); color: #4f46e5; }
  .sidebar-active { background: rgba(99,102,241,0.1); color: #4f46e5; font-weight: 600; }
  .sidebar-divider { height: 1px; background: rgba(200,200,220,0.3); margin: 10px 0; }
  .sidebar-storage { padding: 0 4px; }
  .storage-label { font-size: 10px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
  .storage-bar { height: 4px; background: rgba(200,200,220,0.4); border-radius: 999px; overflow: hidden; margin-bottom: 5px; }
  .storage-fill { height: 100%; width: 28%; background: linear-gradient(90deg, #6366f1, #a855f7); border-radius: 999px; }
  .storage-text { font-size: 10px; color: #94a3b8; }
  .mock-main { flex: 1; display: flex; flex-direction: column; padding: 14px; overflow: hidden; }
  .mock-toolbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
  .mock-section-label { font-size: 13px; font-weight: 700; color: #1e1b4b; letter-spacing: -0.2px; }
  .mock-toolbar-actions { display: flex; gap: 4px; }
  .toolbar-btn {
    width: 26px; height: 26px; border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    color: #94a3b8; cursor: pointer; transition: all 0.15s;
  }
  .toolbar-btn:hover, .active-view { background: rgba(99,102,241,0.1); color: #6366f1; }
  .mock-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(105px, 1fr)); gap: 10px; }
  .mock-file {
    border-radius: 10px;
    border: 1px solid rgba(200,200,220,0.35);
    background: rgba(255,255,255,0.8);
    padding: 12px 10px 10px;
    display: flex; flex-direction: column; align-items: center;
    gap: 6px; cursor: pointer; transition: all 0.2s; min-height: 84px;
  }
  .mock-file:hover {
    border-color: rgba(99,102,241,0.3); background: white;
    transform: translateY(-2px); box-shadow: 0 4px 16px rgba(99,102,241,0.1);
  }
  .file-icon { width: 32px; height: 32px; border-radius: 7px; display: flex; align-items: center; justify-content: center; }
  .folder-icon   { background: linear-gradient(135deg, #fbbf24, #f59e0b); color: white; }
  .folder-purple { background: linear-gradient(135deg, #a78bfa, #7c3aed); color: white; }
  .image-icon    { background: linear-gradient(135deg, #34d399, #10b981); color: white; }
  .doc-icon      { background: linear-gradient(135deg, #60a5fa, #3b82f6); color: white; }
  .video-icon    { background: linear-gradient(135deg, #f87171, #ef4444); color: white; }
  .file-name { font-size: 11px; font-weight: 500; color: #1e293b; line-height: 1.3; word-break: break-word; }
  .file-meta { font-size: 10px; color: #94a3b8; }
  .mock-upload {
    border-style: dashed; border-color: rgba(99,102,241,0.25);
    background: rgba(99,102,241,0.02); align-items: center; justify-content: center;
  }
  .mock-upload:hover { border-color: rgba(99,102,241,0.45); background: rgba(99,102,241,0.05); }
  .upload-icon {
    width: 32px; height: 32px; border-radius: 8px;
    background: rgba(99,102,241,0.1);
    display: flex; align-items: center; justify-content: center; color: #6366f1;
  }
  .float-card {
    position: absolute; display: flex; align-items: center; gap: 10px;
    padding: 10px 14px; border-radius: 12px;
    background: rgba(255,255,255,0.9); backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.95);
    box-shadow: 0 8px 32px rgba(99,102,241,0.12), 0 2px 8px rgba(0,0,0,0.06);
    font-size: 12px; opacity: 0; pointer-events: none;
    transition: opacity 0.35s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .float-card-1 { bottom: -14px; left: -16px; transform: translate(8px, -8px); transition-delay: 0.05s; }
  .float-card-2 { top: 56px; right: -20px; transform: translate(-8px, 8px); transition-delay: 0.1s; }
  .mock-wrapper:hover .float-card { opacity: 1; transform: translate(0, 0); }
  .float-icon {
    width: 28px; height: 28px; border-radius: 7px;
    background: linear-gradient(135deg, #34d399, #10b981);
    color: white; display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 700; flex-shrink: 0;
  }
  .float-avatar {
    width: 28px; height: 28px; border-radius: 7px;
    background: linear-gradient(135deg, #6366f1, #a855f7);
    color: white; display: flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 700; flex-shrink: 0;
  }
  .float-title { font-weight: 600; color: #1e293b; font-size: 12px; }
  .float-sub { color: #94a3b8; font-size: 11px; margin-top: 1px; }
</style>

<script>
  const wrapper = document.getElementById('mockWrapper');
  const frame = document.getElementById('mockFrame');

  if (wrapper && frame) {
    wrapper.addEventListener('mousemove', (e) => {
      const rect = wrapper.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      frame.style.transition = 'transform 0.08s ease, box-shadow 0.3s ease';
      frame.style.transform = `translateY(-6px) rotateX(${-y * 6}deg) rotateY(${x * 6}deg)`;
      frame.style.boxShadow = '0 0 0 1px rgba(200,200,240,0.4), 0 40px 100px rgba(99,102,241,0.18), 0 16px 48px rgba(0,0,0,0.1)';
    });

    wrapper.addEventListener('mouseleave', () => {
      frame.style.transition = 'transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.4s ease';
      frame.style.transform = '';
      frame.style.boxShadow = '';
    });

    wrapper.addEventListener('mousedown', () => {
      frame.style.transition = 'transform 0.1s ease';
      frame.style.transform = frame.style.transform.replace('translateY(-6px)', 'translateY(-3px)') + ' scale(0.985)';
    });

    wrapper.addEventListener('mouseup', () => {
      frame.style.transition = 'transform 0.08s ease';
      frame.style.transform = frame.style.transform.replace(' scale(0.985)', '').replace('translateY(-3px)', 'translateY(-6px)');
    });
  }
</script>